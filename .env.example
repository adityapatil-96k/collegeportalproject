# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/college_portal

# JWT secret (use a long random string in production)
JWT_SECRET=change_this_to_a_long_random_secret

PORT=5000

# Public base URL of this app (approval links in emails). No trailing slash.
APP_BASE_URL=http://localhost:5000
FRONTEND_BASE_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

ADMIN_EMAIL=admin@example.com

# SMTP (Gmail: use App Password on port 465 + SMTP_SECURE=true, or 587 + SMTP_SECURE=false)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# Sender shown to recipients (RFC format recommended)
MAIL_FROM="College App <your@gmail.com>"

# Cloudinary (PDF uploads via raw resource_type)
CLOUDINARY_CLOUD_NAME=dtsovgnwg
CLOUDINARY_API_KEY=416333377964854
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Cloudinary folder to store teacher resources
CLOUDINARY_FOLDER=college-resources
